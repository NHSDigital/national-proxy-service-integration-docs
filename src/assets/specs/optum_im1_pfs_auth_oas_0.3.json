              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Emis.PatientFacingServices.ExternalModel.ErrorModel"
                },
                "examples": {
                  "UserNotFound": {
                    "summary": "User has no online account",
                    "value": {
                      "message": "No online account exists for the given user."
                    }
                  },
                  "PatientNotFound": {
                    "summary": "No patient record",
                    "value": {
