            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Emis.PatientFacingServices.ExternalModel.Users.CreateNHSloginUserSessionRequestModel"
              },
              "examples": {
                "UserIsThePatient": {
                  "summary": "User and Patient have the same NHS number",
                  "description": "User and Patient have the same NHS number and therefore represents a request for a patient at the practice with an online user account",
