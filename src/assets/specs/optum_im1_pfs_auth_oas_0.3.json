                    "UserIdentifier": {
                      "IdentifierValue": "9434765919",
                      "IdentifierType": "NhsNumber"
                    },
                    "PatientIdentifier": {
                      "IdentifierValue": "9434765919",
                      "IdentifierType": "NhsNumber"
                    },
                    "PatientNationalPracticeCode": "A82648"
                  }
                },
                "UserAndPatientDifferent": {
