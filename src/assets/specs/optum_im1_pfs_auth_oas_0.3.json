            "name": "X-API-ApplicationId",
            "in": "header",
            "description": "The identity of the subsidiary",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "X-API-Version",
            "in": "header",
            "description": "The version of the API requested",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Request model with details obtained from an NHS login issued access token",
